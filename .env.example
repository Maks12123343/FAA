# Copy this file to .env and fill in your values
# start.sh loads this automatically

# Bind address — keep 127.0.0.1 when nginx is in front
FAA_HOST=127.0.0.1
FAA_PORT=5050

# HTTP Basic Auth — REQUIRED on server (app refuses to start without these)
FAA_USER=admin
FAA_PASS=change_me_strong_password

# Flask session secret (generated automatically by start.sh if omitted)
# FAA_SECRET_KEY=

# CORS — set to your public domain once HTTPS is configured
# Example: https://faa.example.com
FAA_CORS_ORIGIN=http://YOUR_SERVER_IP

# Local development only — set to 1 to skip the auth requirement
# FAA_DEV=1
